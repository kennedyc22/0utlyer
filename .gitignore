# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# audit harness — research artefacts, not part of the deployed site
/audit/

# playwright
/test-results/
/playwright-report/
/playwright/.cache/
# Playwright visual fixtures (regenerated locally; not needed at deploy time)
/tests/screenshots/
# QA artefacts produced by Phase 7-final spec runs (a11y reports, focus
# states, colour-deficiency screenshots, schema dumps, link reports). These
# are regenerated each CI run and uploaded as workflow artefacts.
/tests/reports/

# lighthouse ci
/.lighthouseci/

# pre-handover verification — local-only evidence (screenshots, report, ad-hoc
# Playwright spec). Not part of the deployed site; excluded from the handover.
/tests/handover/

# Windows attachment metadata (created when files are copied from the web/email)
*:Zone.Identifier
**/Zone.Identifier
