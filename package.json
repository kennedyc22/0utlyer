{
  "name": "outlyer-rebuild",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-llms-txt.ts",
    "build": "next build",
    "gen:llms": "tsx scripts/generate-llms-txt.ts",
    "gen:favicons": "tsx scripts/generate-favicons.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ci": "start-server-and-test \"npm start\" http://localhost:3000 \"playwright test\"",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test:links": "playwright test tests/e2e/link-integrity.spec.ts",
    "qa:reports": "node -e \"const o=require('os'),c=require('child_process');const p=require('path').resolve('tests/reports');const cmd=o.platform()==='win32'?'explorer':o.platform()==='darwin'?'open':'xdg-open';c.spawn(cmd,[p],{stdio:'ignore',detached:true}).unref()\"",
    "qa:visuals": "node -e \"const o=require('os'),c=require('child_process');const p=require('path').resolve('tests/visual/__snapshots__');const cmd=o.platform()==='win32'?'explorer':o.platform()==='darwin'?'open':'xdg-open';c.spawn(cmd,[p],{stdio:'ignore',detached:true}).unref()\"",
    "qa:focus": "node -e \"const o=require('os'),c=require('child_process');const p=require('path').resolve('tests/reports/focus-states');const cmd=o.platform()==='win32'?'explorer':o.platform()==='darwin'?'open':'xdg-open';c.spawn(cmd,[p],{stdio:'ignore',detached:true}).unref()\"",
    "qa:colour": "node -e \"const o=require('os'),c=require('child_process');const p=require('path').resolve('tests/reports/colour-deficiency');const cmd=o.platform()==='win32'?'explorer':o.platform()==='darwin'?'open':'xdg-open';c.spawn(cmd,[p],{stdio:'ignore',detached:true}).unref()\"",
    "ci:local": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e:ci",
    "lhci": "lhci autorun",
    "lhci:ci": "start-server-and-test \"npm start\" http://localhost:3000 \"lhci autorun --config=lighthouserc.ci.json\"",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "schema-dts": "^1.1.5",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,css}": [
      "prettier --write"
    ]
  }
}
